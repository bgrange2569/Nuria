\f1 \uc0\u9881 \u65039 
\f0  \'c9TAPE 2 \'97 Pr\'e9parer et transformer les donn\'e9es\
Il faut convertir vos donn\'e9es structur\'e9es en texte lisible pour le LLM.\
\
import json\
\
with open("garmin_activities.json") as f:\
    activities = json.load(f)\
\
docs = []\
for act in activities:\
    texte = f"""\
    Date : \{act.get('startTimeLocal')\}\
    Type : \{act.get('activityType', \{\}).get('typeKey')\}\
    Distance : \{round(act.get('distance', 0) / 1000, 2)\} km\
    Dur\'e9e : \{act.get('duration', 0) // 60\} min\
    FC moyenne : \{act.get('averageHR')\} bpm | FC max : \{act.get('maxHR')\} bpm\
    Allure moyenne : \{act.get('averageSpeed')\} m/s\
    D\'e9nivel\'e9 positif : \{act.get('elevationGain')\} m\
    Calories : \{act.get('calories')\} kcal\
    VO2 Max estim\'e9 : \{act.get('vO2MaxValue')\}\
    Charge d'entra\'eenement : \{act.get('activityTrainingLoad')\}\
    """\
    docs.append(texte.strip())\
Python\

\f1 \uc0\u55358 \u56800 
\f0  \'c9TAPE 3 \'97 Configurer Ollama + RAG\
3.1 \'97 Installer Ollama et t\'e9l\'e9charger les mod\'e8les\
# Installer Ollama : https://ollama.com\
ollama pull llama3        # LLM principal (conseils, analyse)\
ollama pull nomic-embed-text  # Mod\'e8le d'embedding pour la vectorisation\
Bash\
3.2 \'97 Mettre en place le pipeline RAG avec LangChain\
pip install langchain langchain-ollama langchain-community chromadb\
Bash\
from langchain_ollama import OllamaEmbeddings, ChatOllama\
from langchain_community.vectorstores import Chroma\
from langchain.text_splitter import RecursiveCharacterTextSplitter\
from langchain.chains import RetrievalQA\
from langchain_core.documents import Document\
\
# 1. Cr\'e9er les documents\
documents = [Document(page_content=doc) for doc in docs]\
\
# 2. Vectoriser et stocker dans ChromaDB (base de donn\'e9es locale)\
embeddings = OllamaEmbeddings(model="nomic-embed-text")\
vectorstore = Chroma.from_documents(documents, embeddings, persist_directory="./garmin_db")\
\
# 3. Cr\'e9er la cha\'eene RAG\
llm = ChatOllama(model="llama3", temperature=0.3)\
retriever = vectorstore.as_retriever(search_kwargs=\{"k": 10\})\
\
qa_chain = RetrievalQA.from_chain_type(\
    llm=llm,\
    retriever=retriever,\
    chain_type="stuff"\
)\
Python\

\f1 \uc0\u55357 \u56492 
